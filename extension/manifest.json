{
  "manifest_version": 3,
  "name": "NavTab 收藏助手",
  "version": "1.0.0",
  "description": "一键收藏当前网页到 NavTab 网址导航",
  "permissions": ["activeTab", "storage"],
  "host_permissions": ["https://api.github.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
